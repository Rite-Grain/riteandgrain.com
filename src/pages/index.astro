---
import Layout from '../layouts/Layout.astro';
const title = "Rite & Grain — Coming Soon";
const description = "Something exceptional is taking shape. Rite & Grain — coming soon.";
---

<Layout title={title} description={description} path="/">
  <div class="home-wrap">
    <main>
      <div class="rule" style="margin-bottom: 2.5rem;">
        <span class="rule-ornament">&#10022;</span>
      </div>

      <h1 class="wordmark">Rite <em>&</em> Grain</h1>
      <p class="tagline">Est. 2025</p>

      <div class="divider"></div>

      <p class="message">
        Something exceptional is taking shape.<br />
        We'll be ready soon.
      </p>

      <p class="contact">
        Inquiries &mdash; <a href="mailto:hello@riteandgrain.com">hello@riteandgrain.com</a>
      </p>

      <p class="tools-link">
        <a href="/tools/">Explore our tools &rarr;</a>
      </p>

      <div class="rule" style="margin-top: 2.5rem;">
        <span class="rule-ornament">&#10022;</span>
      </div>
    </main>
  </div>

  <footer class="footer">
    &copy; 2025 Rite &amp; Grain &nbsp;&middot;&nbsp; All Rights Reserved
  </footer>

  <style>
    .home-wrap {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100dvh - 5rem);
      padding: 2rem;
    }

    main {
      text-align: center;
      max-width: 640px;
      width: 100%;
    }

    .wordmark {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(3rem, 10vw, 5.5rem);
      letter-spacing: 0.12em;
      line-height: 1;
      color: var(--color-tan-light);
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }

    .wordmark em {
      font-style: italic;
      color: var(--color-tan);
    }

    .tagline {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: clamp(0.65rem, 2vw, 0.75rem);
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin-bottom: 3rem;
    }

    .divider {
      width: 1px;
      height: 3rem;
      background: linear-gradient(to bottom, var(--color-border), transparent);
      margin: 0 auto 3rem;
    }

    .message {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.2rem, 4vw, 1.65rem);
      line-height: 1.6;
      color: var(--color-cream);
      opacity: 0.85;
      margin-bottom: 3rem;
    }

    .contact {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin-bottom: 2rem;
    }

    .contact a {
      color: var(--color-tan);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s, color 0.2s;
    }

    .contact a:hover {
      color: var(--color-tan-light);
      border-bottom-color: var(--color-gold);
    }

    .tools-link {
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    .tools-link a {
      color: var(--color-tan);
      text-decoration: none;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0.3rem;
      transition: border-color 0.2s, color 0.2s;
    }

    .tools-link a:hover {
      color: var(--color-tan-light);
      border-bottom-color: var(--color-gold);
    }
  </style>
</Layout>
