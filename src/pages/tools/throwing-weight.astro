---
import Layout from '../../layouts/Layout.astro';
import CoffeeTip from '../../components/CoffeeTip.astro';
import { clayBodies, cones, defaultCone } from '../../data/clay';
---

<Layout
  title="Throwing Weight Guide — Rite & Grain"
  description="Pick a form, enter your target finished dimensions, and get the wedged-up weight you need — with handle and lid allowances."
  path="/tools/throwing-weight/"
>
  <nav class="site-nav">
    <a href="/" class="brand">Rite <em>&amp;</em> Grain</a>
    <a href="/tools/">&larr; Tools</a>
  </nav>

  <main class="tool-page">
    <header class="tool-header">
      <div class="rule"><span class="rule-ornament">&#10022;</span></div>
      <h1>Throwing Weight</h1>
      <p class="sub">Workshop Calc</p>
    </header>

    <p class="mode-hint">
      Pick a form and enter your <em>finished</em> dimensions &mdash; we&rsquo;ll compute the wedged-up weight, scaled for shrinkage, with optional handle and lid allowances.
    </p>

    <div class="inputs">
      <!-- Form (always visible) -->
      <div class="input-row">
        <label class="input-label" for="form">Form</label>
        <div class="input-wrap">
          <select class="select-field" id="form" autocomplete="off">
            <option value="mug" selected>Mug / Cup</option>
            <option value="bowl">Bowl</option>
            <option value="plate">Plate</option>
            <option value="vase">Vase / Moon Jar</option>
            <option value="jar">Jar</option>
          </select>
        </div>
      </div>

      <!-- Length Unit -->
      <div class="input-row unit-row">
        <label class="input-label">Length Unit</label>
        <div class="input-wrap unit-toggle" role="radiogroup" aria-label="Length unit">
          <button class="unit-btn active" data-unit="in" type="button" role="radio" aria-checked="true">in</button>
          <button class="unit-btn" data-unit="cm" type="button" role="radio" aria-checked="false">cm</button>
        </div>
      </div>

      <!-- Cone -->
      <div class="input-row">
        <label class="input-label" for="cone">Cone</label>
        <div class="input-wrap">
          <select class="select-field" id="cone" autocomplete="off">
            {cones.map((c) => (
              <option value={c.id} selected={c.id === defaultCone}>{c.label}</option>
            ))}
          </select>
        </div>
      </div>

      <!-- Clay Body -->
      <div class="input-row">
        <label class="input-label" for="clay">Clay Body</label>
        <div class="input-wrap combobox" id="clayCombobox">
          <input
            class="input-field combobox-input"
            id="clay"
            type="text"
            autocomplete="off"
            spellcheck="false"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="clayPanel"
            placeholder="Search clay bodies…"
          />
          <span class="combobox-chevron" aria-hidden="true">&#9662;</span>
          <div class="combobox-panel" id="clayPanel" role="listbox" hidden></div>
        </div>
      </div>

      <!-- Plate: Diameter -->
      <div class="input-row" data-rowkey="plateD" hidden>
        <label class="input-label" for="plateD">Diameter</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="plateD" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Plate: Thickness -->
      <div class="input-row" data-rowkey="plateThick" hidden>
        <label class="input-label" for="plateThick">Thickness</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="plateThick" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Height (mug/bowl/vase/jar) -->
      <div class="input-row" data-rowkey="height">
        <label class="input-label" for="height">Height</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="height" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Top / Rim / Mouth Ø (mug, bowl, vase) -->
      <div class="input-row" data-rowkey="topD">
        <label class="input-label" for="mouthD" id="topDLabel">Top Ø</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="mouthD" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Chamber Ø (vase) -->
      <div class="input-row" data-rowkey="chamberD" hidden>
        <label class="input-label" for="chamberD">Chamber Ø</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="chamberD" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Chamber Height (vase) -->
      <div class="input-row" data-rowkey="chamberH" hidden>
        <label class="input-label" for="chamberH">Chamber Ht</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="chamberH" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Base / Foot Ø (mug, bowl, vase) -->
      <div class="input-row" data-rowkey="baseD">
        <label class="input-label" for="baseD" id="baseDLabel">Base Ø</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="baseD" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Jar Diameter -->
      <div class="input-row" data-rowkey="jarD" hidden>
        <label class="input-label" for="jarD">Diameter</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="jarD" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Walls -->
      <div class="input-row" data-rowkey="wall">
        <label class="input-label" for="wall">Walls</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="wall" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Base Thick -->
      <div class="input-row" data-rowkey="baseT">
        <label class="input-label" for="baseT">Base Thick</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="baseT" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Throw Waste -->
      <div class="input-row">
        <label class="input-label" for="throwWaste">Throw Waste</label>
        <div class="input-wrap slider-wrap">
          <input class="range-slider" type="range" min="0" max="15" step="1" value="5" id="throwWaste" />
          <span class="slider-value" id="throwWasteValue">5%</span>
        </div>
      </div>

      <!-- Trim Waste -->
      <div class="input-row">
        <label class="input-label" for="trimWaste">Trim Waste</label>
        <div class="input-wrap slider-wrap">
          <input class="range-slider" type="range" min="0" max="30" step="1" value="15" id="trimWaste" />
          <span class="slider-value" id="trimWasteValue">15%</span>
        </div>
      </div>

      <!-- Include Handle (not plate) -->
      <div class="input-row" id="includeHandleRow">
        <label class="input-label" for="includeHandle">Handle</label>
        <div class="input-wrap checkbox-wrap">
          <label class="checkbox-inline">
            <input type="checkbox" id="includeHandle" />
            <span class="checkbox-label">Include handle allowance</span>
          </label>
        </div>
      </div>

      <!-- Handle Style (when include handle checked) -->
      <div class="input-row" id="handleStyleRow" hidden>
        <label class="input-label" for="handleStyle">Style</label>
        <div class="input-wrap">
          <select class="select-field" id="handleStyle" autocomplete="off">
            <option value="pulled-s">Pulled, small — ~25 g</option>
            <option value="pulled-m" selected>Pulled, medium — ~45 g</option>
            <option value="pulled-l">Pulled, large — ~75 g</option>
            <option value="molded">Molded — ~50 g</option>
            <option value="slab">Slab — ¼″ × 1″ × 7″ (~53 g)</option>
            <option value="custom">Custom</option>
          </select>
        </div>
      </div>

      <!-- Handle Weight -->
      <div class="input-row" id="handleWeightRow" hidden>
        <label class="input-label" for="handleWeight">Weight</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="handleWeight" placeholder="&mdash;" />
          <span class="unit-echo">g</span>
        </div>
      </div>

      <!-- Include Lid (not plate) -->
      <div class="input-row" id="includeLidRow">
        <label class="input-label" for="includeLid">Lid</label>
        <div class="input-wrap checkbox-wrap">
          <label class="checkbox-inline">
            <input type="checkbox" id="includeLid" />
            <span class="checkbox-label">Include lid allowance</span>
          </label>
        </div>
      </div>

      <!-- Lid Diameter -->
      <div class="input-row" id="lidDRow" hidden>
        <label class="input-label" for="lidD">Lid Ø</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="lidD" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Lid Thickness -->
      <div class="input-row" id="lidThickRow" hidden>
        <label class="input-label" for="lidThick">Lid Thick</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="lidThick" placeholder="&mdash;" />
          <span class="unit-echo" data-len-unit>in</span>
        </div>
      </div>

      <!-- Knob Weight (optional) -->
      <div class="input-row" id="knobWeightRow" hidden>
        <label class="input-label" for="knobWeight">Knob</label>
        <div class="input-wrap input-with-unit">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="knobWeight" placeholder="&mdash;" />
          <span class="unit-echo">g</span>
        </div>
      </div>
    </div>

    <p class="clay-warning" id="clayWarning" role="alert" hidden>
      <span class="warn-icon" aria-hidden="true">&#9888;</span>
      <span id="clayWarningText"></span>
    </p>

    <section class="result" id="result" aria-live="polite">
      <div class="result-label">Wedge up</div>
      <div class="result-value" id="resultValue">&mdash;</div>
      <div class="result-sub" id="resultSub">&nbsp;</div>
      <div class="result-breakdown" id="resultBreakdown" hidden></div>
    </section>

    <aside class="notes">
      <h3>Notes</h3>
      <ul>
        <li><strong>Clay weight</strong> uses ~1.85 g/cm³ wet-clay density; actual varies by body and moisture.</li>
        <li><strong>Slab handle</strong> preset = ¼″ × 1″ × 7″ strip (~53 g wet).</li>
        <li><strong>Fractions work:</strong> type <em>1/8</em>, <em>3/4</em>, or <em>1 1/2</em> &mdash; or decimals like <em>0.125</em>.</li>
      </ul>
    </aside>

    <CoffeeTip />
  </main>

  <footer class="footer">
    &copy; 2025 Rite &amp; Grain &nbsp;&middot;&nbsp; All Rights Reserved
  </footer>

  <script is:inline define:vars={{ CLAY_BODIES: clayBodies }}>
    (function () {
      // -------- constants --------
      const CM_PER_IN    = 2.54;
      const CM3_PER_IN3  = 16.387064;
      const CLAY_DENSITY_G_CM3 = 1.85;
      const G_PER_OZ     = 28.3495;
      const G_PER_LB     = 453.592;
      const STORAGE_KEY  = 'rag-throwing-v1';

      const HANDLE_PRESETS = {
        'pulled-s': 25,
        'pulled-m': 45,
        'pulled-l': 75,
        'molded':   50,
        'slab':     53,
      };

      const FORM_CONFIG = {
        'mug':   { rowKeys: ['height', 'topD', 'baseD', 'wall', 'baseT'],
                   labels: { topD: 'Top Ø',   baseD: 'Base Ø' },
                   allowHandle: true,  allowLid: true,  geom: 'frustum' },
        'bowl':  { rowKeys: ['height', 'topD', 'baseD', 'wall', 'baseT'],
                   labels: { topD: 'Rim Ø',   baseD: 'Foot Ø' },
                   allowHandle: true,  allowLid: true,  geom: 'frustum' },
        'plate': { rowKeys: ['plateD', 'plateThick'],
                   labels: {},
                   allowHandle: false, allowLid: false, geom: 'plate' },
        'vase':  { rowKeys: ['height', 'topD', 'chamberD', 'chamberH', 'baseD', 'wall', 'baseT'],
                   labels: { topD: 'Mouth Ø', baseD: 'Foot Ø' },
                   allowHandle: true,  allowLid: true,  geom: 'two-frustum' },
        'jar':   { rowKeys: ['height', 'jarD', 'wall', 'baseT'],
                   labels: {},
                   allowHandle: true,  allowLid: true,  geom: 'cylinder' },
      };

      // -------- elements --------
      const formEl        = document.getElementById('form');
      const unitBtns      = document.querySelectorAll('.unit-btn');
      const unitEchoes    = document.querySelectorAll('[data-len-unit]');
      const coneEl        = document.getElementById('cone');
      const clayEl        = document.getElementById('clay');
      const clayComboboxEl = document.getElementById('clayCombobox');
      const clayPanelEl   = document.getElementById('clayPanel');
      const warnEl        = document.getElementById('clayWarning');
      const warnTextEl    = document.getElementById('clayWarningText');

      const plateDEl      = document.getElementById('plateD');
      const plateThickEl  = document.getElementById('plateThick');

      const heightEl      = document.getElementById('height');
      const mouthEl       = document.getElementById('mouthD');
      const chamberDEl    = document.getElementById('chamberD');
      const chamberHEl    = document.getElementById('chamberH');
      const baseEl        = document.getElementById('baseD');
      const jarDEl        = document.getElementById('jarD');
      const wallEl        = document.getElementById('wall');
      const baseTEl       = document.getElementById('baseT');

      const topDLabel     = document.getElementById('topDLabel');
      const baseDLabel    = document.getElementById('baseDLabel');

      const throwWasteEl  = document.getElementById('throwWaste');
      const throwWasteValueEl = document.getElementById('throwWasteValue');
      const trimWasteEl   = document.getElementById('trimWaste');
      const trimWasteValueEl = document.getElementById('trimWasteValue');

      const includeHandleRow = document.getElementById('includeHandleRow');
      const includeHandleEl  = document.getElementById('includeHandle');
      const handleStyleRow = document.getElementById('handleStyleRow');
      const handleWeightRow = document.getElementById('handleWeightRow');
      const handleStyleEl  = document.getElementById('handleStyle');
      const handleWeightEl = document.getElementById('handleWeight');

      const includeLidRow  = document.getElementById('includeLidRow');
      const includeLidEl   = document.getElementById('includeLid');
      const lidDRow        = document.getElementById('lidDRow');
      const lidThickRow    = document.getElementById('lidThickRow');
      const knobWeightRow  = document.getElementById('knobWeightRow');
      const lidDEl         = document.getElementById('lidD');
      const lidThickEl     = document.getElementById('lidThick');
      const knobWeightEl   = document.getElementById('knobWeight');

      const resultValueEl = document.getElementById('resultValue');
      const resultSubEl   = document.getElementById('resultSub');
      const resultBreakEl = document.getElementById('resultBreakdown');

      // -------- state --------
      let lengthUnit = 'in';
      let selectedClayId = '';
      let comboOpen = false;
      let comboHighlight = -1;
      let comboItems = [];
      let saveTimer = null;

      // -------- utilities --------
      function parseNum(s) {
        if (s === null || s === undefined) return null;
        s = String(s).trim();
        if (!s) return null;
        // Mixed fraction, e.g. "1 1/2" → 1.5
        const mixed = s.match(/^(\d+(?:\.\d+)?)\s+(\d+(?:\.\d+)?)\s*\/\s*(\d+(?:\.\d+)?)$/);
        if (mixed) {
          const w = parseFloat(mixed[1]);
          const num = parseFloat(mixed[2]);
          const den = parseFloat(mixed[3]);
          if (den === 0 || isNaN(w) || isNaN(num) || isNaN(den)) return null;
          return w + num / den;
        }
        // Simple fraction, e.g. "1/8" → 0.125
        const frac = s.match(/^(\d+(?:\.\d+)?)\s*\/\s*(\d+(?:\.\d+)?)$/);
        if (frac) {
          const num = parseFloat(frac[1]);
          const den = parseFloat(frac[2]);
          if (den === 0 || isNaN(num) || isNaN(den)) return null;
          return num / den;
        }
        const n = parseFloat(s);
        return isNaN(n) ? null : n;
      }

      function fmt(n, digits) {
        if (n === null || n === undefined || isNaN(n)) return '—';
        if (digits === undefined) digits = 3;
        return parseFloat(n.toFixed(digits)).toString();
      }

      function currentForm() { return formEl.value || 'mug'; }
      function currentCone() { return coneEl.value || '6'; }
      function coneLabel(c)  { return 'Cone ' + c; }

      function bodyShrinkageAtCone(body, cone) {
        if (!body || !body.shrinkage) return undefined;
        return body.shrinkage[cone];
      }

      function getBodyById(id) {
        if (!id) return null;
        for (let i = 0; i < CLAY_BODIES.length; i++) {
          if (CLAY_BODIES[i].id === id) return CLAY_BODIES[i];
        }
        return null;
      }

      function bodiesForCurrentCone() {
        const cone = currentCone();
        return CLAY_BODIES.filter(b => bodyShrinkageAtCone(b, cone) !== undefined);
      }

      function canonicalDisplay(body) {
        if (!body) return '';
        const pct = bodyShrinkageAtCone(body, currentCone());
        if (pct === undefined) return body.name;
        return body.name + ' · ' + pct.toFixed(2) + '%';
      }

      function clearClay() {
        selectedClayId = '';
        clayEl.value = '';
        clayEl.removeAttribute('data-clay-id');
      }

      function setClayById(id) {
        const body = getBodyById(id);
        if (!body) { clearClay(); return false; }
        const pct = bodyShrinkageAtCone(body, currentCone());
        if (pct === undefined) { clearClay(); return false; }
        selectedClayId = id;
        clayEl.value = canonicalDisplay(body);
        clayEl.setAttribute('data-clay-id', id);
        return true;
      }

      function refreshClaySelection() {
        if (!selectedClayId) return;
        const body = getBodyById(selectedClayId);
        const pct = body ? bodyShrinkageAtCone(body, currentCone()) : undefined;
        if (!body || pct === undefined) clearClay();
        else clayEl.value = canonicalDisplay(body);
      }

      function selectedClay() {
        if (!selectedClayId) return null;
        const body = getBodyById(selectedClayId);
        if (!body) return null;
        const cone = currentCone();
        const pct = bodyShrinkageAtCone(body, cone);
        if (pct === undefined) return null;
        return { id: body.id, name: body.name, shrinkage: pct, cone: cone, note: body.note || null };
      }

      function updateClayWarning() {
        const clay = selectedClay();
        if (clay && clay.note) {
          warnTextEl.textContent = clay.name + ' — ' + clay.note + '.';
          warnEl.hidden = false;
        } else {
          warnEl.hidden = true;
        }
      }

      // -------- combobox --------
      function escapeHtml(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      function filterBodies(query) {
        const bodies = bodiesForCurrentCone();
        const q = String(query || '').trim().toLowerCase();
        if (!q) return bodies;
        return bodies.filter(b => (b.name + ' ' + b.group).toLowerCase().indexOf(q) !== -1);
      }

      function renderComboPanel(query) {
        const cone = currentCone();
        const filtered = filterBodies(query);
        comboItems = filtered;
        if (filtered.length === 0) {
          const hasQ = String(query || '').trim() !== '';
          const ratedCount = bodiesForCurrentCone().length;
          const msg = ratedCount === 0
            ? 'No clay bodies rated for ' + coneLabel(cone) + '.'
            : (hasQ ? 'No rated bodies match that search at ' + coneLabel(cone) + '.'
                    : 'No clay bodies rated for ' + coneLabel(cone) + '.');
          clayPanelEl.innerHTML = '<div class="combo-empty">' + escapeHtml(msg) + '</div>';
          return;
        }
        const groupOrder = [];
        const groupItems = {};
        for (let i = 0; i < filtered.length; i++) {
          const b = filtered[i];
          if (!groupItems[b.group]) { groupItems[b.group] = []; groupOrder.push(b.group); }
          groupItems[b.group].push({ body: b, flatIdx: i });
        }
        let html = '';
        for (let g = 0; g < groupOrder.length; g++) {
          const group = groupOrder[g];
          html += '<div class="combo-group-label">' + escapeHtml(group) + '</div>';
          const entries = groupItems[group];
          for (let j = 0; j < entries.length; j++) {
            const b = entries[j].body;
            const idx = entries[j].flatIdx;
            const pct = bodyShrinkageAtCone(b, cone);
            const classes = ['combo-item'];
            if (idx === comboHighlight) classes.push('is-active');
            if (b.id === selectedClayId) classes.push('is-selected');
            if (b.note) classes.push('has-note');
            html += '<div class="' + classes.join(' ') + '"' +
              ' role="option" aria-selected="' + (idx === comboHighlight ? 'true' : 'false') + '"' +
              ' data-idx="' + idx + '" data-id="' + escapeHtml(b.id) + '">' +
              '<span class="combo-item-name">' + escapeHtml(b.name) + '</span>' +
              '<span class="combo-item-pct">' + pct.toFixed(2) + '%</span></div>';
          }
        }
        clayPanelEl.innerHTML = html;
        const active = clayPanelEl.querySelector('.combo-item.is-active');
        if (active && active.scrollIntoView) active.scrollIntoView({ block: 'nearest' });
      }

      function openCombobox() {
        if (comboOpen) return;
        comboOpen = true;
        clayEl.setAttribute('aria-expanded', 'true');
        clayPanelEl.hidden = false;
        renderComboPanel(clayEl.value);
      }

      function closeCombobox() {
        if (!comboOpen) return;
        comboOpen = false;
        comboHighlight = -1;
        clayEl.setAttribute('aria-expanded', 'false');
        clayPanelEl.hidden = true;
      }

      function commitSelection(id) {
        setClayById(id);
        closeCombobox();
        recalc();
        saveSettings();
      }

      // -------- unit helpers --------
      function toInches(val) {
        if (val === null || isNaN(val)) return null;
        return lengthUnit === 'cm' ? val / CM_PER_IN : val;
      }
      function fromInches(inches) {
        if (inches === null || isNaN(inches)) return null;
        return lengthUnit === 'cm' ? inches * CM_PER_IN : inches;
      }
      function lenStr(inches) {
        const v = fromInches(inches);
        return fmt(v, lengthUnit === 'cm' ? 2 : 3) + ' ' + lengthUnit;
      }
      function weightStr(g) {
        if (g === null || isNaN(g)) return '—';
        const lb = g / G_PER_LB;
        if (g >= 1000) return fmt(g / 1000, 2) + ' kg · ' + fmt(lb, 2) + ' lb';
        if (lb >= 0.5) return fmt(g, 0) + ' g · ' + fmt(lb, 2) + ' lb';
        const oz = g / G_PER_OZ;
        return fmt(g, 0) + ' g · ' + fmt(oz, 1) + ' oz';
      }

      // -------- math --------
      function frustumVolume(h, R, r) {
        return Math.PI * h / 3 * (R*R + R*r + r*r);
      }

      function calcFrustum() {
        const height = toInches(parseNum(heightEl.value));
        const topD   = toInches(parseNum(mouthEl.value));
        const baseD  = toInches(parseNum(baseEl.value));
        const wall   = toInches(parseNum(wallEl.value));
        const baseT  = toInches(parseNum(baseTEl.value));

        const clay = selectedClay();
        if (height === null || topD === null || baseD === null || wall === null || baseT === null) return null;
        if (!clay) return { error: 'Choose a clay body above.' };
        if (height <= 0 || topD <= 0 || baseD <= 0 || wall <= 0 || baseT <= 0) return { error: 'All values must be positive.' };

        const intTopR = (topD - 2 * wall) / 2;
        const intBaseR = (baseD - 2 * wall) / 2;
        if (intTopR <= 0 || intBaseR <= 0) return { error: 'Walls leave no interior — check dimensions.' };
        const intHeight = height - baseT;
        if (intHeight <= 0) return { error: 'Base thickness meets or exceeds height.' };

        const topR = topD / 2;
        const baseR = baseD / 2;
        const extVol = frustumVolume(height, topR, baseR);
        const intVol = frustumVolume(intHeight, intTopR, intBaseR);
        const clayVolFinalIn3 = extVol - intVol;

        const s = clay.shrinkage / 100;
        const tf = 1 / (1 - s);
        const clayVolWetIn3 = clayVolFinalIn3 * tf * tf * tf;

        return {
          clay, clayVolWetIn3, throwFactor: tf,
          thrownHeight: height * tf,
          thrownTopD: topD * tf,
          thrownBaseD: baseD * tf,
          thrownWall: wall * tf,
          thrownBaseT: baseT * tf,
        };
      }

      function calcCylinder() {
        const height = toInches(parseNum(heightEl.value));
        const d      = toInches(parseNum(jarDEl.value));
        const wall   = toInches(parseNum(wallEl.value));
        const baseT  = toInches(parseNum(baseTEl.value));

        const clay = selectedClay();
        if (height === null || d === null || wall === null || baseT === null) return null;
        if (!clay) return { error: 'Choose a clay body above.' };
        if (height <= 0 || d <= 0 || wall <= 0 || baseT <= 0) return { error: 'All values must be positive.' };

        const R = d / 2;
        const intR = R - wall;
        if (intR <= 0) return { error: 'Walls leave no interior — check dimensions.' };
        const intHeight = height - baseT;
        if (intHeight <= 0) return { error: 'Base thickness meets or exceeds height.' };

        const extVol = Math.PI * R * R * height;
        const intVol = Math.PI * intR * intR * intHeight;
        const clayVolFinalIn3 = extVol - intVol;

        const s = clay.shrinkage / 100;
        const tf = 1 / (1 - s);
        const clayVolWetIn3 = clayVolFinalIn3 * tf * tf * tf;

        return {
          clay, clayVolWetIn3, throwFactor: tf,
          thrownHeight: height * tf,
          thrownD: d * tf,
          thrownWall: wall * tf,
          thrownBaseT: baseT * tf,
        };
      }

      function calcPlate() {
        const d = toInches(parseNum(plateDEl.value));
        const t = toInches(parseNum(plateThickEl.value));

        const clay = selectedClay();
        if (d === null || t === null) return null;
        if (!clay) return { error: 'Choose a clay body above.' };
        if (d <= 0 || t <= 0) return { error: 'All values must be positive.' };

        const R = d / 2;
        const clayVolFinalIn3 = Math.PI * R * R * t;

        const s = clay.shrinkage / 100;
        const tf = 1 / (1 - s);
        const clayVolWetIn3 = clayVolFinalIn3 * tf * tf * tf;

        return {
          clay, clayVolWetIn3, throwFactor: tf,
          thrownD: d * tf,
          thrownThick: t * tf,
        };
      }

      function calcTwoFrustum() {
        const height   = toInches(parseNum(heightEl.value));
        const mouthD   = toInches(parseNum(mouthEl.value));
        const chamberD = toInches(parseNum(chamberDEl.value));
        const chamberH = toInches(parseNum(chamberHEl.value));
        const footD    = toInches(parseNum(baseEl.value));
        const wall     = toInches(parseNum(wallEl.value));
        const baseT    = toInches(parseNum(baseTEl.value));

        const clay = selectedClay();
        const vals = [height, mouthD, chamberD, chamberH, footD, wall, baseT];
        if (vals.some(function (v) { return v === null; })) return null;
        if (!clay) return { error: 'Choose a clay body above.' };
        if (vals.some(function (v) { return v <= 0; })) return { error: 'All values must be positive.' };
        if (chamberH >= height) return { error: 'Chamber height must be less than total height.' };
        if (baseT >= chamberH) return { error: 'Base thickness exceeds chamber height.' };

        const mouthR   = mouthD / 2;
        const chamberR = chamberD / 2;
        const footR    = footD / 2;
        const intMouthR   = mouthR - wall;
        const intChamberR = chamberR - wall;
        const intFootR    = footR - wall;
        if (intMouthR <= 0 || intChamberR <= 0 || intFootR <= 0) {
          return { error: 'Walls leave no interior — check dimensions.' };
        }

        const upperH = height - chamberH;

        // Exterior
        const extVolLower = frustumVolume(chamberH, chamberR, footR);
        const extVolUpper = frustumVolume(upperH, chamberR, mouthR);
        const extVolTotal = extVolLower + extVolUpper;

        // Interior: starts at z=baseT; interpolate outer radius there
        const startFrac = baseT / chamberH;
        const outerAtStart = footR + (chamberR - footR) * startFrac;
        const intLowerBotR = outerAtStart - wall;
        if (intLowerBotR <= 0) return { error: 'Walls leave no interior at the foot — check dimensions.' };
        const intLowerH = chamberH - baseT;

        const intVolLower = frustumVolume(intLowerH, intChamberR, intLowerBotR);
        const intVolUpper = frustumVolume(upperH, intChamberR, intMouthR);
        const intVolTotal = intVolLower + intVolUpper;

        const clayVolFinalIn3 = extVolTotal - intVolTotal;

        const s = clay.shrinkage / 100;
        const tf = 1 / (1 - s);
        const clayVolWetIn3 = clayVolFinalIn3 * tf * tf * tf;

        return {
          clay, clayVolWetIn3, throwFactor: tf,
          thrownHeight: height * tf,
          thrownMouthD: mouthD * tf,
          thrownChamberD: chamberD * tf,
          thrownChamberH: chamberH * tf,
          thrownFootD: footD * tf,
          thrownWall: wall * tf,
          thrownBaseT: baseT * tf,
        };
      }

      function calc() {
        const form = currentForm();
        const config = FORM_CONFIG[form];
        let result;
        if (config.geom === 'plate') result = calcPlate();
        else if (config.geom === 'cylinder') result = calcCylinder();
        else if (config.geom === 'two-frustum') result = calcTwoFrustum();
        else result = calcFrustum();

        if (!result || result.error) return result;

        result.form = form;
        attachWasteAndAccessories(result);
        return result;
      }

      function attachWasteAndAccessories(r) {
        const bodyPieceG = r.clayVolWetIn3 * CM3_PER_IN3 * CLAY_DENSITY_G_CM3;

        const throwPct = parseNum(throwWasteEl.value) || 0;
        const trimPct  = parseNum(trimWasteEl.value)  || 0;
        const throwAddG = bodyPieceG * (throwPct / 100);
        const afterThrowG = bodyPieceG + throwAddG;
        const trimAddG  = afterThrowG * (trimPct / 100);
        const bodyWeightG = afterThrowG + trimAddG;

        // Handle
        let handleWeightG = 0, handleStyle = null;
        if (includeHandleEl.checked && FORM_CONFIG[r.form].allowHandle) {
          const w = parseNum(handleWeightEl.value);
          handleWeightG = (w !== null && w > 0) ? w : 0;
          handleStyle = handleStyleEl.value;
        }

        // Lid — disc model
        let lidBodyG = 0, knobG = 0, lidD = null, lidT = null;
        if (includeLidEl.checked && FORM_CONFIG[r.form].allowLid) {
          lidD = toInches(parseNum(lidDEl.value));
          lidT = toInches(parseNum(lidThickEl.value));
          if (lidD !== null && lidT !== null && lidD > 0 && lidT > 0) {
            const lidFinalIn3 = Math.PI * (lidD / 2) * (lidD / 2) * lidT;
            const tf = r.throwFactor;
            const lidWetIn3 = lidFinalIn3 * tf * tf * tf;
            lidBodyG = lidWetIn3 * CM3_PER_IN3 * CLAY_DENSITY_G_CM3;
          }
          const k = parseNum(knobWeightEl.value);
          knobG = (k !== null && k > 0) ? k : 0;
        }

        const lidTotalG = lidBodyG + knobG;
        const totalWeightG = bodyWeightG + handleWeightG + lidTotalG;
        const totalVolCm3 = totalWeightG / CLAY_DENSITY_G_CM3;
        const totalVolIn3 = totalVolCm3 / CM3_PER_IN3;

        r.bodyPieceG = bodyPieceG;
        r.throwPct = throwPct;
        r.trimPct = trimPct;
        r.throwAddG = throwAddG;
        r.trimAddG = trimAddG;
        r.bodyWeightG = bodyWeightG;
        r.handleWeightG = handleWeightG;
        r.handleStyle = handleStyle;
        r.lidBodyG = lidBodyG;
        r.knobG = knobG;
        r.lidTotalG = lidTotalG;
        r.lidD = lidD;
        r.lidT = lidT;
        r.totalWeightG = totalWeightG;
        r.totalVolCm3 = totalVolCm3;
        r.totalVolIn3 = totalVolIn3;
      }

      function handleStyleLabel(v) {
        return v === 'slab' ? 'slab'
             : v === 'pulled-s' ? 'pulled, small'
             : v === 'pulled-m' ? 'pulled, medium'
             : v === 'pulled-l' ? 'pulled, large'
             : v === 'molded'   ? 'molded'
             : v === 'custom'   ? 'custom'
             : v || '';
      }

      function renderResult(r) {
        updateClayWarning();
        if (!r) {
          resultValueEl.textContent = '—';
          resultSubEl.innerHTML = '&nbsp;';
          resultBreakEl.hidden = true;
          return;
        }
        if (r.error) {
          resultValueEl.textContent = '—';
          resultSubEl.textContent = r.error;
          resultBreakEl.hidden = true;
          return;
        }

        resultValueEl.textContent = weightStr(r.totalWeightG);
        resultSubEl.textContent = r.clay.name + ' · ' + coneLabel(r.clay.cone) +
          ' · ' + r.clay.shrinkage.toFixed(2) + '% shrinkage';

        let throwToParts = [];
        if (r.form === 'plate') {
          throwToParts.push('<dt>Throw to</dt><dd>' + lenStr(r.thrownD) + ' ⌀ · ' + lenStr(r.thrownThick) + ' thick</dd>');
        } else if (r.form === 'jar') {
          throwToParts.push('<dt>Throw to</dt><dd>' + lenStr(r.thrownHeight) + ' H · ' + lenStr(r.thrownD) + ' ⌀</dd>');
          throwToParts.push('<dt>Thrown walls</dt><dd>' + lenStr(r.thrownWall) + ' · base ' + lenStr(r.thrownBaseT) + ' thick</dd>');
        } else if (r.form === 'vase') {
          throwToParts.push('<dt>Throw to</dt><dd>' + lenStr(r.thrownHeight) + ' H · ' +
            lenStr(r.thrownMouthD) + ' ⌀ mouth · ' +
            lenStr(r.thrownChamberD) + ' ⌀ chamber · ' +
            lenStr(r.thrownFootD) + ' ⌀ foot</dd>');
          throwToParts.push('<dt>Chamber at</dt><dd>' + lenStr(r.thrownChamberH) + ' from base</dd>');
          throwToParts.push('<dt>Thrown walls</dt><dd>' + lenStr(r.thrownWall) + ' · base ' + lenStr(r.thrownBaseT) + ' thick</dd>');
        } else {
          const topLabel = r.form === 'bowl' ? 'rim' : 'top';
          const baseLabel = r.form === 'bowl' ? 'foot' : 'base';
          throwToParts.push('<dt>Throw to</dt><dd>' + lenStr(r.thrownHeight) + ' H · ' +
            lenStr(r.thrownTopD) + ' ⌀ ' + topLabel + ' · ' +
            lenStr(r.thrownBaseD) + ' ⌀ ' + baseLabel + '</dd>');
          throwToParts.push('<dt>Thrown walls</dt><dd>' + lenStr(r.thrownWall) + ' · base ' + lenStr(r.thrownBaseT) + ' thick</dd>');
        }

        const throwLine = r.throwPct > 0
          ? '<dt>Throw waste (' + r.throwPct + '%)</dt><dd>+' + fmt(r.throwAddG, 0) + ' g</dd>' : '';
        const trimLine = r.trimPct > 0
          ? '<dt>Trim waste (' + r.trimPct + '%)</dt><dd>+' + fmt(r.trimAddG, 0) + ' g</dd>' : '';
        const handleLine = r.handleWeightG > 0
          ? '<dt>Handle (' + escapeHtml(handleStyleLabel(r.handleStyle)) + ')</dt><dd>' + fmt(r.handleWeightG, 0) + ' g</dd>' : '';

        const lidParts = [];
        if (r.lidBodyG > 0) {
          lidParts.push('<dt>Lid body</dt><dd>' + fmt(r.lidBodyG, 0) + ' g · ' +
            lenStr(r.lidD) + ' ⌀ × ' + lenStr(r.lidT) + ' thick</dd>');
        }
        if (r.knobG > 0) {
          lidParts.push('<dt>Knob</dt><dd>' + fmt(r.knobG, 0) + ' g</dd>');
        }

        resultBreakEl.hidden = false;
        resultBreakEl.innerHTML =
          '<dl>' +
            throwToParts.join('') +
            '<dt>Body (piece mass)</dt><dd>' + weightStr(r.bodyPieceG) + '</dd>' +
            throwLine +
            trimLine +
            handleLine +
            lidParts.join('') +
            '<dt>Total</dt><dd>' + weightStr(r.totalWeightG) + '</dd>' +
            '<dt>Clay volume (wet)</dt><dd>' + fmt(r.totalVolCm3, 0) + ' cm³ · ' + fmt(r.totalVolIn3, 2) + ' in³</dd>' +
          '</dl>';
      }

      function recalc() { renderResult(calc()); }

      // -------- form UI --------
      function updateFormUI() {
        const form = currentForm();
        const config = FORM_CONFIG[form];

        document.querySelectorAll('[data-rowkey]').forEach(function (el) {
          const key = el.dataset.rowkey;
          el.hidden = config.rowKeys.indexOf(key) === -1;
        });

        if (config.labels.topD && topDLabel) topDLabel.textContent = config.labels.topD;
        else if (topDLabel) topDLabel.textContent = 'Top Ø';
        if (config.labels.baseD && baseDLabel) baseDLabel.textContent = config.labels.baseD;
        else if (baseDLabel) baseDLabel.textContent = 'Base Ø';

        includeHandleRow.hidden = !config.allowHandle;
        includeLidRow.hidden = !config.allowLid;
        if (!config.allowHandle) includeHandleEl.checked = false;
        if (!config.allowLid) includeLidEl.checked = false;
        syncHandleUI();
        syncLidUI();
      }

      formEl.addEventListener('change', function () {
        updateFormUI();
        recalc();
        saveSettings();
      });

      // -------- waste sliders --------
      function updateSliderFill(el) {
        const min = parseFloat(el.min) || 0;
        const max = parseFloat(el.max) || 100;
        const val = parseFloat(el.value) || 0;
        const pct = ((val - min) / (max - min)) * 100;
        el.style.background =
          'linear-gradient(to right, var(--color-gold) 0%, var(--color-gold) ' + pct + '%, ' +
          'var(--color-border) ' + pct + '%, var(--color-border) 100%)';
      }
      function wireWasteSlider(sliderEl, valueEl) {
        const sync = function () {
          valueEl.textContent = sliderEl.value + '%';
          updateSliderFill(sliderEl);
        };
        sliderEl.addEventListener('input', function () { sync(); recalc(); scheduleSave(); });
        sync();
      }
      wireWasteSlider(throwWasteEl, throwWasteValueEl);
      wireWasteSlider(trimWasteEl, trimWasteValueEl);

      // -------- handle section --------
      function syncHandleUI() {
        const form = currentForm();
        const allow = FORM_CONFIG[form].allowHandle;
        const on = allow && includeHandleEl.checked;
        handleStyleRow.hidden = !on;
        handleWeightRow.hidden = !on;
      }

      function applyHandleStyle(style) {
        if (style !== 'custom' && HANDLE_PRESETS[style] !== undefined) {
          handleWeightEl.value = String(HANDLE_PRESETS[style]);
        }
      }

      includeHandleEl.addEventListener('change', function () {
        syncHandleUI();
        if (includeHandleEl.checked && !handleWeightEl.value) {
          applyHandleStyle(handleStyleEl.value);
        }
        recalc();
        saveSettings();
      });

      handleStyleEl.addEventListener('change', function () {
        applyHandleStyle(handleStyleEl.value);
        recalc();
        saveSettings();
      });

      handleWeightEl.addEventListener('input', function () {
        if (handleStyleEl.value !== 'custom') handleStyleEl.value = 'custom';
        recalc();
        scheduleSave();
      });

      // -------- lid section --------
      function syncLidUI() {
        const form = currentForm();
        const allow = FORM_CONFIG[form].allowLid;
        const on = allow && includeLidEl.checked;
        lidDRow.hidden = !on;
        lidThickRow.hidden = !on;
        knobWeightRow.hidden = !on;
      }

      includeLidEl.addEventListener('change', function () {
        syncLidUI();
        recalc();
        saveSettings();
      });

      [lidDEl, lidThickEl, knobWeightEl].forEach(function (el) {
        el.addEventListener('input', function () { recalc(); scheduleSave(); });
      });

      // -------- unit toggle --------
      function setLengthUnit(u) {
        if (u !== 'in' && u !== 'cm') return;
        if (u === lengthUnit) return;
        const prev = lengthUnit;
        lengthUnit = u;
        const factor = (prev === 'in' && u === 'cm') ? CM_PER_IN
                     : (prev === 'cm' && u === 'in') ? (1 / CM_PER_IN)
                     : 1;
        [heightEl, mouthEl, chamberDEl, chamberHEl, baseEl, jarDEl, wallEl, baseTEl, plateDEl, plateThickEl, lidDEl, lidThickEl].forEach(function (el) {
          const n = parseNum(el.value);
          if (n !== null) el.value = fmt(n * factor, u === 'cm' ? 2 : 3);
        });
        unitBtns.forEach(function (b) {
          const active = b.dataset.unit === u;
          b.classList.toggle('active', active);
          b.setAttribute('aria-checked', active ? 'true' : 'false');
        });
        unitEchoes.forEach(function (el) { el.textContent = u; });
        recalc();
        saveSettings();
      }
      unitBtns.forEach(function (b) {
        b.addEventListener('click', function () { setLengthUnit(b.dataset.unit); });
      });

      // -------- dimension inputs --------
      [heightEl, mouthEl, chamberDEl, chamberHEl, baseEl, jarDEl, wallEl, baseTEl, plateDEl, plateThickEl].forEach(function (el) {
        el.addEventListener('input', function () { recalc(); scheduleSave(); });
      });

      coneEl.addEventListener('change', function () {
        refreshClaySelection();
        if (comboOpen) { comboHighlight = -1; renderComboPanel(clayEl.value); }
        recalc();
        saveSettings();
      });

      // -------- clay combobox wiring --------
      clayEl.addEventListener('focus', function () {
        if (selectedClayId) clayEl.value = '';
        comboHighlight = -1;
        openCombobox();
        clayEl.select();
      });
      clayEl.addEventListener('input', function () {
        if (selectedClayId) { selectedClayId = ''; clayEl.removeAttribute('data-clay-id'); }
        comboHighlight = -1;
        openCombobox();
        renderComboPanel(clayEl.value);
        recalc();
        scheduleSave();
      });
      clayEl.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (!comboOpen) openCombobox();
          if (comboItems.length === 0) return;
          comboHighlight = (comboHighlight + 1) % comboItems.length;
          renderComboPanel(clayEl.value);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (!comboOpen) openCombobox();
          if (comboItems.length === 0) return;
          comboHighlight = comboHighlight <= 0 ? comboItems.length - 1 : comboHighlight - 1;
          renderComboPanel(clayEl.value);
        } else if (e.key === 'Enter') {
          if (comboOpen && comboHighlight >= 0 && comboItems[comboHighlight]) {
            e.preventDefault();
            commitSelection(comboItems[comboHighlight].id);
          }
        } else if (e.key === 'Escape') {
          if (comboOpen) {
            e.preventDefault();
            closeCombobox();
            if (selectedClayId) {
              const body = getBodyById(selectedClayId);
              if (body) clayEl.value = canonicalDisplay(body);
            } else {
              clayEl.value = '';
            }
            clayEl.blur();
          }
        }
      });
      clayEl.addEventListener('blur', function () {
        if (selectedClayId) {
          const body = getBodyById(selectedClayId);
          if (body) clayEl.value = canonicalDisplay(body);
        } else {
          clayEl.value = '';
        }
        closeCombobox();
        recalc();
        saveSettings();
      });
      clayPanelEl.addEventListener('mousedown', function (e) {
        const item = e.target.closest && e.target.closest('.combo-item');
        if (!item) return;
        e.preventDefault();
        const id = item.getAttribute('data-id');
        if (id) commitSelection(id);
      });
      document.addEventListener('mousedown', function (e) {
        if (!comboOpen) return;
        if (clayComboboxEl.contains(e.target)) return;
        closeCombobox();
      });

      // -------- persistence --------
      function scheduleSave() {
        clearTimeout(saveTimer);
        saveTimer = setTimeout(saveSettings, 400);
      }

      function saveSettings() {
        try {
          localStorage.setItem(STORAGE_KEY + ':settings', JSON.stringify({
            form: formEl.value,
            lengthUnit: lengthUnit,
            cone: coneEl.value,
            lastClay: selectedClayId,
            height: heightEl.value,
            mouthD: mouthEl.value,
            chamberD: chamberDEl.value,
            chamberH: chamberHEl.value,
            baseD: baseEl.value,
            jarD: jarDEl.value,
            plateD: plateDEl.value,
            plateThick: plateThickEl.value,
            wall: wallEl.value,
            baseT: baseTEl.value,
            throwWaste: throwWasteEl.value,
            trimWaste: trimWasteEl.value,
            includeHandle: includeHandleEl.checked,
            handleStyle: handleStyleEl.value,
            handleWeight: handleWeightEl.value,
            includeLid: includeLidEl.checked,
            lidD: lidDEl.value,
            lidThick: lidThickEl.value,
            knobWeight: knobWeightEl.value,
          }));
        } catch (e) { /* ignore */ }
      }

      function load() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY + ':settings');
          if (!raw) return;
          const d = JSON.parse(raw);

          if (d.form) {
            const opt = formEl.querySelector('option[value="' + String(d.form).replace(/"/g, '\\"') + '"]');
            if (opt) formEl.value = d.form;
          }
          if (d.lengthUnit === 'in' || d.lengthUnit === 'cm') lengthUnit = d.lengthUnit;
          if (d.cone) {
            const opt = coneEl.querySelector('option[value="' + String(d.cone).replace(/"/g, '\\"') + '"]');
            if (opt) coneEl.value = d.cone;
          }
          if (d.height !== undefined) heightEl.value = d.height;
          if (d.mouthD !== undefined) mouthEl.value = d.mouthD;
          if (d.chamberD !== undefined) chamberDEl.value = d.chamberD;
          if (d.chamberH !== undefined) chamberHEl.value = d.chamberH;
          if (d.baseD  !== undefined) baseEl.value = d.baseD;
          if (d.jarD   !== undefined) jarDEl.value = d.jarD;
          if (d.plateD !== undefined) plateDEl.value = d.plateD;
          if (d.plateThick !== undefined) plateThickEl.value = d.plateThick;
          if (d.wall   !== undefined) wallEl.value = d.wall;
          if (d.baseT  !== undefined) baseTEl.value = d.baseT;
          if (d.throwWaste !== undefined) throwWasteEl.value = d.throwWaste;
          if (d.trimWaste  !== undefined) trimWasteEl.value  = d.trimWaste;

          if (d.includeHandle) includeHandleEl.checked = true;
          if (d.handleStyle) {
            const opt = handleStyleEl.querySelector('option[value="' + String(d.handleStyle).replace(/"/g, '\\"') + '"]');
            if (opt) handleStyleEl.value = d.handleStyle;
          }
          if (d.handleWeight !== undefined) handleWeightEl.value = d.handleWeight;

          if (d.includeLid) includeLidEl.checked = true;
          if (d.lidD !== undefined) lidDEl.value = d.lidD;
          if (d.lidThick !== undefined) lidThickEl.value = d.lidThick;
          if (d.knobWeight !== undefined) knobWeightEl.value = d.knobWeight;

          if (d.lastClay) setClayById(d.lastClay);
        } catch (e) { /* no settings yet */ }
      }

      // -------- init --------
      load();
      unitBtns.forEach(function (b) {
        const active = b.dataset.unit === lengthUnit;
        b.classList.toggle('active', active);
        b.setAttribute('aria-checked', active ? 'true' : 'false');
      });
      unitEchoes.forEach(function (el) { el.textContent = lengthUnit; });
      throwWasteValueEl.textContent = throwWasteEl.value + '%';
      trimWasteValueEl.textContent = trimWasteEl.value + '%';
      updateSliderFill(throwWasteEl);
      updateSliderFill(trimWasteEl);
      updateFormUI();
      if (includeHandleEl.checked && !handleWeightEl.value) {
        applyHandleStyle(handleStyleEl.value);
      }
      recalc();
    })();
  </script>

