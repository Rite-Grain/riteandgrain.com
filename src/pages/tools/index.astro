---
import Layout from '../../layouts/Layout.astro';

const tools = [
  {
    href: '/tools/shrinkage/',
    name: 'Shrinkage Calculator',
    description:
      'Compute cooking or processing loss — yield percentage, shrinkage percentage, and weight lost.',
    available: true,
  },
];
---

<Layout
  title="Tools — Rite & Grain"
  description="A growing collection of craft tools and calculators."
  path="/tools/"
>
  <nav class="site-nav">
    <a href="/" class="brand">Rite <em>&amp;</em> Grain</a>
    <a href="/">&larr; Home</a>
  </nav>

  <main class="tools-page">
    <header class="tools-header">
      <div class="rule"><span class="rule-ornament">&#10022;</span></div>
      <h1>Tools</h1>
      <p class="lede">
        A small collection of utilities, refined over time.<br />
        Made for those who measure carefully.
      </p>
    </header>

    <ul class="tool-list">
      {tools.map((tool) => (
        <li class={`tool-card${tool.available ? '' : ' disabled'}`}>
          {tool.available ? (
            <a href={tool.href}>
              <h2>{tool.name}</h2>
              <p>{tool.description}</p>
              <span class="arrow">&rarr;</span>
            </a>
          ) : (
            <div>
              <h2>{tool.name}</h2>
              <p>{tool.description}</p>
              <span class="soon">Coming soon</span>
            </div>
          )}
        </li>
      ))}
    </ul>
  </main>

  <footer class="footer">
    &copy; 2025 Rite &amp; Grain &nbsp;&middot;&nbsp; All Rights Reserved
  </footer>

  <style>
    .tools-page {
      position: relative;
      z-index: 1;
      max-width: 760px;
      margin: 0 auto;
      padding: 2rem 2rem 4rem;
    }

    .tools-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .tools-header .rule {
      margin-bottom: 1.75rem;
    }

    .tools-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(2.5rem, 7vw, 4rem);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-tan-light);
      margin-bottom: 1rem;
    }

    .lede {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: clamp(1rem, 2.5vw, 1.2rem);
      color: var(--color-cream);
      opacity: 0.75;
      line-height: 1.6;
    }

    .tool-list {
      list-style: none;
      display: grid;
      gap: 1.25rem;
    }

    .tool-card a,
    .tool-card > div {
      display: block;
      padding: 1.75rem 2rem;
      background: linear-gradient(180deg, var(--color-surface) 0%, rgba(42, 31, 23, 0.6) 100%);
      border: 1px solid var(--color-border);
      border-radius: 2px;
      text-decoration: none;
      color: inherit;
      position: relative;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }

    .tool-card a:hover {
      border-color: var(--color-gold);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px -12px rgba(184, 144, 42, 0.25);
    }

    .tool-card h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 400;
      font-size: 1.65rem;
      letter-spacing: 0.05em;
      color: var(--color-tan-light);
      margin-bottom: 0.5rem;
    }

    .tool-card p {
      color: var(--color-cream);
      opacity: 0.7;
      font-size: 0.9rem;
      line-height: 1.6;
      max-width: 52ch;
    }

    .tool-card .arrow {
      position: absolute;
      top: 1.75rem;
      right: 2rem;
      color: var(--color-gold);
      font-size: 1.2rem;
      transition: transform 0.2s;
    }

    .tool-card a:hover .arrow {
      transform: translateX(4px);
    }

    .tool-card.disabled > div {
      opacity: 0.5;
    }

    .tool-card .soon {
      display: inline-block;
      margin-top: 0.75rem;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--color-muted);
    }
  </style>
</Layout>
