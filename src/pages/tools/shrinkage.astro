---
import Layout from '../../layouts/Layout.astro';

// Firing cones the studio uses. Default is Cone 6.
const cones = [
  { id: '04', label: 'Cone 04' },
  { id: '5',  label: 'Cone 5'  },
  { id: '6',  label: 'Cone 6'  },
];
const defaultCone = '6';

// Studio clay bodies with per-cone total shrinkage.
// Values from each maker's published data sheet; verify against your own fires.
type ClayBody = {
  id: string;
  group: string;
  name: string;
  shrinkage: Partial<Record<'04' | '5' | '6', number>>;
  note?: string;
};

const clayBodies: ClayBody[] = [
  // --- Georgies (Cone 4–7 Mid-Range) ---
  { id: 'g-mix-6',                group: 'Georgies', name: 'G-Mix 6',                    shrinkage: { '04': 5.36,  '6': 10.92 } },
  { id: 'g-mix-6-grog',           group: 'Georgies', name: 'G-Mix 6 with Grog',          shrinkage: { '04': 6.37,  '6': 11.12 } },
  { id: 'kristy-lombard',         group: 'Georgies', name: 'Kristy Lombard',             shrinkage: { '04': 6.23,  '6': 11.50 } },
  { id: 'mazama-red',             group: 'Georgies', name: 'Mazama Red',                 shrinkage: { '04': 8.31,  '6': 13.50 } },
  { id: 'pat-horsley',            group: 'Georgies', name: 'Pat Horsley',                shrinkage: { '04': 6.13,  '6': 11.23 } },
  { id: 'pioneer-dark',           group: 'Georgies', name: 'Pioneer Dark',               shrinkage: { '04': 7.51,  '6': 11.23 } },
  { id: 'pioneer-dark-spkd',      group: 'Georgies', name: 'Pioneer Dark w/ Speckles',   shrinkage: { '04': 7.33,  '6': 10.99 } },
  { id: 'rogue-river-buff',       group: 'Georgies', name: 'Rogue River Buff',           shrinkage: { '04': 6.30,  '6': 11.94 } },
  { id: 'silver-falls-porcelain', group: 'Georgies', name: 'Silver Falls Porcelain',     shrinkage: { '04': 4.69,  '6': 12.03 } },
  { id: 'timberline',             group: 'Georgies', name: 'Timberline',                 shrinkage: { '04': 6.65,  '6': 11.50 } },
  { id: 'timberline-sculptural',  group: 'Georgies', name: 'Timberline Sculptural',      shrinkage: { '04': 6.01,  '6': 8.36  } },
  { id: 'trail-mix',              group: 'Georgies', name: 'Trail Mix',                  shrinkage: { '04': 6.95,  '6': 11.59 } },
  { id: 'trail-mix-cinnamon',     group: 'Georgies', name: 'Trail Mix Cinnamon',         shrinkage: { '04': 6.86,  '6': 11.86 } },
  { id: 'trail-mix-chocolate',    group: 'Georgies', name: 'Trail Mix Dark Chocolate',   shrinkage: { '04': 10.17, '6': 13.05 } },
  { id: 'trail-mix-toast',        group: 'Georgies', name: 'Trail Mix Toast',            shrinkage: { '04': 6.86,  '6': 11.07 } },
  { id: 'trillium-porcelain',     group: 'Georgies', name: 'Trillium Porcelain',         shrinkage: { '04': 6.29,  '6': 11.65 } },
  { id: 'white-salmon',           group: 'Georgies', name: 'White Salmon',               shrinkage: {              '6': 11.32 } },
  { id: 'white-salmon-grog',      group: 'Georgies', name: 'White Salmon with Grog',     shrinkage: { '04': 8.13,  '6': 9.97  } },
  { id: 'white-salmon-spkd',      group: 'Georgies', name: 'White Salmon w/ Speckles',   shrinkage: { '04': 6.95,  '6': 11.32 } },

  // --- Laguna (Cone 5–6 Mid-Fire) ---
  { id: 'laguna-50',              group: 'Laguna',   name: '50 (WC606)',                 shrinkage: { '6': 12.00 } },
  { id: 'laguna-60',              group: 'Laguna',   name: '60 (WC608)',                 shrinkage: { '6': 10.90 } },
  { id: 'laguna-75',              group: 'Laguna',   name: '75 (WC612)',                 shrinkage: { '6': 12.50 } },
  { id: 'azabache-black',         group: 'Laguna',   name: 'Azabache Black',             shrinkage: { '5': 13.00 }, note: 'Do not fire past Cone 5' },
  { id: 'bmix-5',                 group: 'Laguna',   name: 'B-Mix 5',                    shrinkage: { '5': 12.00 } },
  { id: 'bmix-5-grog',            group: 'Laguna',   name: 'B-Mix 5 with Grog',          shrinkage: { '5': 11.00 } },
  { id: 'bmix-5-speckles',        group: 'Laguna',   name: 'B-Mix 5 w/ Speckles',        shrinkage: { '5': 12.47 } },
  { id: 'calico',                 group: 'Laguna',   name: 'Calico',                     shrinkage: { '5': 13.00 } },
  { id: 'dark-horse',             group: 'Laguna',   name: 'Dark Horse',                 shrinkage: { '5': 9.00  }, note: 'Do not fire past Cone 5' },
  { id: 'frost-porcelain',        group: 'Laguna',   name: 'Frost Porcelain',            shrinkage: { '5': 11.00, '6': 11.00 } },
  { id: 'greystone-off-white',    group: 'Laguna',   name: 'Greystone Off-White',        shrinkage: { '5': 12.50, '6': 12.50 } },
  { id: 'half-half',              group: 'Laguna',   name: 'Half & Half',                shrinkage: { '5': 12.00 } },
  { id: 'red-bmix-grog',          group: 'Laguna',   name: 'Red B-Mix with Grog',        shrinkage: { '5': 9.00  } },
  { id: 'redstone',               group: 'Laguna',   name: 'Redstone',                   shrinkage: { '5': 10.50, '6': 10.50 } },
  { id: 'rsmc-special',           group: 'Laguna',   name: 'RSMC Special',               shrinkage: { '5': 12.00, '6': 12.00 } },
  { id: 'ws-5',                   group: 'Laguna',   name: 'WS-5',                       shrinkage: { '5': 10.00 } },
];

const clayGroups: Record<string, ClayBody[]> = {};
for (const body of clayBodies) {
  (clayGroups[body.group] ??= []).push(body);
}
---

<Layout
  title="Shrinkage Calculator — Rite & Grain"
  description="Workshop shrinkage calculator — compute the final size from a starting size, or reverse the math to oversize a piece that will shrink to a target."
  path="/tools/shrinkage/"
>
  <nav class="site-nav">
    <a href="/" class="brand">Rite <em>&amp;</em> Grain</a>
    <a href="/tools/">&larr; Tools</a>
  </nav>

  <main class="tool-page">
    <header class="tool-header">
      <div class="rule"><span class="rule-ornament">&#10022;</span></div>
      <h1>Shrinkage</h1>
      <p class="sub">Workshop Calc</p>
    </header>

    <div class="mode-toggle" role="tablist">
      <div class="mode-indicator" id="modeIndicator"></div>
      <button class="mode-btn active" data-mode="forward" type="button">Starting &rarr; Final</button>
      <button class="mode-btn" data-mode="reverse" type="button">Target &larr; Starting</button>
    </div>

    <p class="mode-hint" id="modeHint">
      Enter a <em>starting size</em> to find what it shrinks to.
    </p>

    <div class="inputs">
      <div class="input-row">
        <label class="input-label" for="cone">Cone</label>
        <div class="input-wrap">
          <select class="select-field" id="cone" autocomplete="off">
            {cones.map((c) => (
              <option value={c.id} selected={c.id === defaultCone}>{c.label}</option>
            ))}
          </select>
        </div>
      </div>
      <div class="input-row">
        <label class="input-label" for="w">Width</label>
        <div class="input-wrap">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="w" placeholder="&mdash;" />
        </div>
      </div>
      <div class="input-row">
        <label class="input-label" for="h">Height</label>
        <div class="input-wrap">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="h" placeholder="&mdash;" />
        </div>
      </div>
      <div class="input-row">
        <label class="input-label" for="clay">Clay Body</label>
        <div class="input-wrap combobox" id="clayCombobox">
          <input
            class="input-field combobox-input"
            id="clay"
            type="text"
            autocomplete="off"
            spellcheck="false"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="clayPanel"
            placeholder="Search clay bodies…"
          />
          <span class="combobox-chevron" aria-hidden="true">&#9662;</span>
          <div class="combobox-panel" id="clayPanel" role="listbox" hidden></div>
        </div>
      </div>
      <div class="input-row">
        <label class="input-label" for="s">Shrinkage</label>
        <div class="input-wrap">
          <input class="input-field" type="text" inputmode="decimal" autocomplete="off" id="s" placeholder="&mdash;" />
          <span class="input-suffix">%</span>
        </div>
      </div>
    </div>

    <p class="clay-warning" id="clayWarning" role="alert" hidden>
      <span class="warn-icon" aria-hidden="true">&#9888;</span>
      <span id="clayWarningText"></span>
    </p>

    <div class="result">
      <div class="result-label" id="resLabel">Final size</div>
      <div class="result-value" id="resValue">&mdash;</div>
      <div class="result-sub" id="resSub">&nbsp;</div>
    </div>

    <div class="history-header">
      <h2 class="history-title">Recent</h2>
      <button class="clear-btn" id="clearBtn" type="button">Clear</button>
    </div>
    <div class="history-list" id="historyList">
      <div class="empty">No calculations yet</div>
    </div>

    <p class="footer-note">Height is optional &middot; tap a row to reuse</p>
  </main>

  <footer class="footer">
    &copy; 2025 Rite &amp; Grain &nbsp;&middot;&nbsp; All Rights Reserved
  </footer>

  <script is:inline define:vars={{ CLAY_BODIES: clayBodies }}>
    (function () {
      const wEl = document.getElementById('w');
      const hEl = document.getElementById('h');
      const sEl = document.getElementById('s');
      const clayEl = document.getElementById('clay');
      const clayComboboxEl = document.getElementById('clayCombobox');
      const clayPanelEl = document.getElementById('clayPanel');
      const coneEl = document.getElementById('cone');
      const resValue = document.getElementById('resValue');
      const resLabel = document.getElementById('resLabel');
      const resSub = document.getElementById('resSub');
      const modeIndicator = document.getElementById('modeIndicator');
      const modeHint = document.getElementById('modeHint');
      const historyList = document.getElementById('historyList');
      const clearBtn = document.getElementById('clearBtn');
      const warnEl = document.getElementById('clayWarning');
      const warnTextEl = document.getElementById('clayWarningText');
      const modeBtns = document.querySelectorAll('.mode-btn');

      // --- Combobox state ---
      let selectedClayId = '';
      let comboOpen = false;
      let comboHighlight = -1;
      let comboItems = []; // last-rendered filtered items (in display order)

      function currentCone() {
        return coneEl.value || '6';
      }

      function coneLabel(c) {
        return 'Cone ' + c;
      }

      function bodyShrinkageAtCone(body, cone) {
        if (!body || !body.shrinkage) return undefined;
        return body.shrinkage[cone];
      }

      function getBodyById(id) {
        if (!id) return null;
        for (let i = 0; i < CLAY_BODIES.length; i++) {
          if (CLAY_BODIES[i].id === id) return CLAY_BODIES[i];
        }
        return null;
      }

      function bodiesForCurrentCone() {
        const cone = currentCone();
        return CLAY_BODIES.filter(b => bodyShrinkageAtCone(b, cone) !== undefined);
      }

      function canonicalDisplay(body) {
        if (!body) return '';
        const pct = bodyShrinkageAtCone(body, currentCone());
        if (pct === undefined) return body.name;
        return body.name + ' · ' + pct.toFixed(2) + '%';
      }

      function clearClay() {
        selectedClayId = '';
        clayEl.value = '';
        clayEl.removeAttribute('data-clay-id');
      }

      // Set the selected clay by id. Returns true on success.
      // Fails silently if the body doesn't exist or isn't rated at the current cone.
      function setClayById(id) {
        const body = getBodyById(id);
        if (!body) { clearClay(); return false; }
        const pct = bodyShrinkageAtCone(body, currentCone());
        if (pct === undefined) { clearClay(); return false; }
        selectedClayId = id;
        clayEl.value = canonicalDisplay(body);
        clayEl.setAttribute('data-clay-id', id);
        return true;
      }

      // Called after a cone change to keep the displayed selection consistent.
      function refreshClaySelection() {
        if (!selectedClayId) return;
        const body = getBodyById(selectedClayId);
        const pct = body ? bodyShrinkageAtCone(body, currentCone()) : undefined;
        if (!body || pct === undefined) {
          clearClay();
        } else {
          clayEl.value = canonicalDisplay(body);
        }
      }

      function selectedClay() {
        if (!selectedClayId) return null;
        const body = getBodyById(selectedClayId);
        if (!body) return null;
        const cone = currentCone();
        const pct = bodyShrinkageAtCone(body, cone);
        if (pct === undefined) return null;
        return {
          id: body.id,
          name: body.name,
          shrinkage: pct,
          cone: cone,
          note: body.note || null,
        };
      }

      // --- Combobox panel ---
      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function filterBodies(query) {
        const bodies = bodiesForCurrentCone();
        const q = String(query || '').trim().toLowerCase();
        if (!q) return bodies;
        return bodies.filter(b => {
          const hay = (b.name + ' ' + b.group).toLowerCase();
          return hay.indexOf(q) !== -1;
        });
      }

      function renderComboPanel(query) {
        const cone = currentCone();
        const filtered = filterBodies(query);
        comboItems = filtered;

        if (filtered.length === 0) {
          const hasQuery = String(query || '').trim() !== '';
          const ratedCount = bodiesForCurrentCone().length;
          let msg;
          if (ratedCount === 0) {
            msg = 'No clay bodies rated for ' + coneLabel(cone) + '.';
          } else if (hasQuery) {
            msg = 'No rated bodies match that search at ' + coneLabel(cone) + '.';
          } else {
            msg = 'No clay bodies rated for ' + coneLabel(cone) + '.';
          }
          clayPanelEl.innerHTML = '<div class="combo-empty">' + escapeHtml(msg) + '</div>';
          return;
        }

        // Group by maker, preserving the ordering in CLAY_BODIES.
        const groupOrder = [];
        const groupItems = {};
        for (let i = 0; i < filtered.length; i++) {
          const b = filtered[i];
          if (!groupItems[b.group]) {
            groupItems[b.group] = [];
            groupOrder.push(b.group);
          }
          groupItems[b.group].push({ body: b, flatIdx: i });
        }

        let html = '';
        for (let g = 0; g < groupOrder.length; g++) {
          const group = groupOrder[g];
          html += '<div class="combo-group-label">' + escapeHtml(group) + '</div>';
          const entries = groupItems[group];
          for (let j = 0; j < entries.length; j++) {
            const b = entries[j].body;
            const idx = entries[j].flatIdx;
            const pct = bodyShrinkageAtCone(b, cone);
            const classes = ['combo-item'];
            if (idx === comboHighlight) classes.push('is-active');
            if (b.id === selectedClayId) classes.push('is-selected');
            if (b.note) classes.push('has-note');
            html += '<div class="' + classes.join(' ') + '"' +
              ' role="option"' +
              ' aria-selected="' + (idx === comboHighlight ? 'true' : 'false') + '"' +
              ' data-idx="' + idx + '"' +
              ' data-id="' + escapeHtml(b.id) + '">' +
              '<span class="combo-item-name">' + escapeHtml(b.name) + '</span>' +
              '<span class="combo-item-pct">' + pct.toFixed(2) + '%</span>' +
              '</div>';
          }
        }
        clayPanelEl.innerHTML = html;
        scrollHighlightIntoView();
      }

      function scrollHighlightIntoView() {
        if (comboHighlight < 0) return;
        const active = clayPanelEl.querySelector('.combo-item.is-active');
        if (active && active.scrollIntoView) {
          active.scrollIntoView({ block: 'nearest' });
        }
      }

      function openCombobox() {
        if (comboOpen) return;
        comboOpen = true;
        clayEl.setAttribute('aria-expanded', 'true');
        clayPanelEl.hidden = false;
        renderComboPanel(clayEl.value);
      }

      function closeCombobox() {
        if (!comboOpen) return;
        comboOpen = false;
        comboHighlight = -1;
        clayEl.setAttribute('aria-expanded', 'false');
        clayPanelEl.hidden = true;
      }

      function commitSelection(id) {
        const ok = setClayById(id);
        if (ok) sEl.value = '';
        closeCombobox();
        calc();
        saveSettings();
        scheduleComplete();
      }

      function updateClayWarning() {
        const clay = selectedClay();
        if (clay && clay.note) {
          warnTextEl.textContent = clay.name + ' — ' + clay.note + '.';
          warnEl.hidden = false;
        } else {
          warnEl.hidden = true;
        }
      }

      function effectiveShrinkage() {
        const clay = selectedClay();
        if (clay) return { value: clay.shrinkage, clay: clay };
        const manual = parseNum(sEl.value);
        if (manual === null) return { value: null, clay: null };
        return { value: manual, clay: null };
      }

      let mode = 'forward';
      let history = [];
      let saveTimer = null;
      let completeTimer = null;
      let lastHistoryKey = null;

      const STORAGE_KEY = 'rag-shrinkage-v1';

      function parseNum(s) {
        if (s === null || s === undefined) return null;
        s = String(s).trim();
        if (!s) return null;
        const n = parseFloat(s);
        return isNaN(n) ? null : n;
      }

      function fmt(n) {
        if (n === null || n === undefined || isNaN(n)) return '—';
        return parseFloat(n.toFixed(4)).toString();
      }

      function updateModeUI() {
        modeBtns.forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
        modeIndicator.classList.toggle('right', mode === 'reverse');
        resLabel.textContent = mode === 'forward' ? 'Final size' : 'Starting size';
        modeHint.innerHTML = mode === 'forward'
          ? 'Enter a <em>starting size</em> to find what it shrinks to.'
          : 'Enter a <em>target final size</em> to find how large to start.';
      }

      function calc() {
        updateClayWarning();
        const w = parseNum(wEl.value);
        const h = parseNum(hEl.value);
        const eff = effectiveShrinkage();
        const s = eff.value;
        const clay = eff.clay;

        if (s === null) {
          resValue.textContent = '—';
          resSub.innerHTML = '&nbsp;';
          return null;
        }

        const factor = 1 - s / 100;
        if (factor <= 0) {
          resValue.textContent = '—';
          resSub.textContent = 'shrinkage must be under 100%';
          return null;
        }

        let wr = null, hr = null;
        if (mode === 'forward') {
          if (w !== null) wr = w * factor;
          if (h !== null) hr = h * factor;
        } else {
          if (w !== null) wr = w / factor;
          if (h !== null) hr = h / factor;
        }

        if (wr === null && hr === null) {
          resValue.textContent = '—';
          resSub.innerHTML = '&nbsp;';
          return null;
        }

        const display = (wr !== null && hr !== null)
          ? fmt(wr) + ' × ' + fmt(hr)
          : fmt(wr !== null ? wr : hr);

        resValue.textContent = display;
        const base = mode === 'forward'
          ? 'after ' + fmt(s) + '% shrinkage'
          : 'start oversized to land at input after ' + fmt(s) + '%';
        resSub.textContent = clay
          ? base + ' · ' + clay.name + ' (' + coneLabel(clay.cone) + ')'
          : base;

        return { w: w, h: h, s: s, wr: wr, hr: hr, clay: clay, cone: currentCone() };
      }

      function setMode(m) {
        if (mode === m) return;
        mode = m;
        updateModeUI();
        calc();
        saveSettings();
        scheduleComplete();
      }

      modeBtns.forEach(b => b.addEventListener('click', () => setMode(b.dataset.mode)));

      function scheduleSave() {
        clearTimeout(saveTimer);
        saveTimer = setTimeout(saveSettings, 400);
      }

      function scheduleComplete() {
        clearTimeout(completeTimer);
        completeTimer = setTimeout(maybeAddHistory, 1500);
      }

      [wEl, hEl].forEach(el => {
        el.addEventListener('input', () => {
          calc();
          scheduleSave();
          scheduleComplete();
        });
        el.addEventListener('blur', maybeAddHistory);
      });

      // Shrinkage % field is mutually exclusive with the clay body selector.
      // Typing here clears any selected clay body.
      sEl.addEventListener('input', () => {
        if (sEl.value.trim() !== '' && selectedClayId) {
          clearClay();
        }
        calc();
        scheduleSave();
        scheduleComplete();
      });
      sEl.addEventListener('blur', maybeAddHistory);

      // --- Clay combobox wiring ---
      clayEl.addEventListener('focus', () => {
        // Clear the displayed selection so the panel shows the full filtered list.
        if (selectedClayId) clayEl.value = '';
        comboHighlight = -1;
        openCombobox();
        clayEl.select();
      });

      clayEl.addEventListener('input', () => {
        // Typing invalidates any committed selection.
        if (selectedClayId) {
          selectedClayId = '';
          clayEl.removeAttribute('data-clay-id');
        }
        comboHighlight = -1;
        openCombobox();
        renderComboPanel(clayEl.value);
        calc();
        scheduleSave();
      });

      clayEl.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (!comboOpen) openCombobox();
          if (comboItems.length === 0) return;
          comboHighlight = (comboHighlight + 1) % comboItems.length;
          renderComboPanel(clayEl.value);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (!comboOpen) openCombobox();
          if (comboItems.length === 0) return;
          comboHighlight = comboHighlight <= 0 ? comboItems.length - 1 : comboHighlight - 1;
          renderComboPanel(clayEl.value);
        } else if (e.key === 'Enter') {
          if (comboOpen && comboHighlight >= 0 && comboItems[comboHighlight]) {
            e.preventDefault();
            commitSelection(comboItems[comboHighlight].id);
          }
        } else if (e.key === 'Escape') {
          if (comboOpen) {
            e.preventDefault();
            closeCombobox();
            // Restore canonical display for whatever is selected (if anything).
            if (selectedClayId) {
              const body = getBodyById(selectedClayId);
              if (body) clayEl.value = canonicalDisplay(body);
            } else {
              clayEl.value = '';
            }
            clayEl.blur();
          }
        }
      });

      clayEl.addEventListener('blur', () => {
        // Restore display state after focus leaves the field.
        if (selectedClayId) {
          const body = getBodyById(selectedClayId);
          if (body) clayEl.value = canonicalDisplay(body);
        } else {
          clayEl.value = '';
        }
        closeCombobox();
        calc();
        saveSettings();
      });

      // Use mousedown so the click lands before the input's blur fires.
      clayPanelEl.addEventListener('mousedown', (e) => {
        const item = e.target.closest && e.target.closest('.combo-item');
        if (!item) return;
        e.preventDefault(); // keep focus on input for keyboard follow-up
        const id = item.getAttribute('data-id');
        if (id) commitSelection(id);
      });

      // Clicking outside the combobox closes the panel.
      document.addEventListener('mousedown', (e) => {
        if (!comboOpen) return;
        if (clayComboboxEl.contains(e.target)) return;
        closeCombobox();
      });

      // Changing the cone re-filters the list and may deselect an unavailable body.
      coneEl.addEventListener('change', () => {
        refreshClaySelection();
        if (comboOpen) {
          comboHighlight = -1;
          renderComboPanel(clayEl.value);
        }
        calc();
        saveSettings();
        scheduleComplete();
      });

      function maybeAddHistory() {
        const r = calc();
        if (!r) return;
        if (r.w === null && r.h === null) return;
        const clayId = r.clay ? r.clay.id : '';
        const cone = r.cone || currentCone();
        const key = mode + '|' + cone + '|' + r.w + '|' + r.h + '|' + r.s + '|' + clayId;
        if (key === lastHistoryKey) return;
        lastHistoryKey = key;

        const entry = {
          mode: mode,
          cone: cone,
          w: r.w,
          h: r.h,
          s: r.s,
          wr: r.wr,
          hr: r.hr,
          clayId: clayId,
          clayName: r.clay ? r.clay.name : null,
          ts: Date.now(),
        };

        history = history.filter(x =>
          !(x.mode === entry.mode &&
            (x.cone || '6') === entry.cone &&
            x.w === entry.w &&
            x.h === entry.h &&
            x.s === entry.s &&
            (x.clayId || '') === entry.clayId));
        history.unshift(entry);
        if (history.length > 12) history = history.slice(0, 12);

        saveHistory();
        renderHistory();
      }

      function renderHistory() {
        if (history.length === 0) {
          historyList.innerHTML = '<div class="empty">No calculations yet</div>';
          return;
        }
        historyList.innerHTML = history.map((e, i) => {
          const inp = (e.w !== null && e.h !== null)
            ? fmt(e.w) + ' × ' + fmt(e.h)
            : fmt(e.w !== null ? e.w : e.h);
          const out = (e.wr !== null && e.hr !== null)
            ? fmt(e.wr) + ' × ' + fmt(e.hr)
            : fmt(e.wr !== null ? e.wr : e.hr);
          const left = e.mode === 'forward' ? inp : out;
          const right = e.mode === 'forward' ? out : inp;
          const clayLabel = e.clayName ? ' · ' + e.clayName : '';
          const coneSuffix = e.cone ? ' · ' + coneLabel(e.cone) : '';
          const metaText = (e.mode === 'forward'
            ? fmt(e.s) + '% shrink'
            : fmt(e.s) + '% · reverse calc') + clayLabel + coneSuffix;
          return (
            '<div class="history-item" data-idx="' + i + '">' +
              '<div class="history-calc">' + left +
                '<span class="history-arrow">&rarr;</span>' +
                right +
              '</div>' +
              '<div class="history-meta">' + metaText + '</div>' +
            '</div>'
          );
        }).join('');

        historyList.querySelectorAll('.history-item').forEach(el => {
          el.addEventListener('click', () => {
            const e = history[parseInt(el.dataset.idx, 10)];
            if (!e) return;
            if (mode !== e.mode) {
              mode = e.mode;
              updateModeUI();
            }
            // Set cone first so the clay lookup resolves at the right cone.
            if (e.cone && coneEl.value !== e.cone) {
              coneEl.value = e.cone;
            }

            wEl.value = e.w !== null ? e.w : '';
            hEl.value = e.h !== null ? e.h : '';
            // Restore either the clay body or the manual %, never both.
            if (e.clayId && setClayById(e.clayId)) {
              sEl.value = '';
            } else {
              clearClay();
              sEl.value = e.s;
            }
            if (comboOpen) {
              comboHighlight = -1;
              renderComboPanel(clayEl.value);
            }
            const clayId = e.clayId || '';
            const cone = e.cone || currentCone();
            lastHistoryKey = mode + '|' + cone + '|' + e.w + '|' + e.h + '|' + e.s + '|' + clayId;
            calc();
            saveSettings();
          });
        });
      }

      function saveSettings() {
        try {
          localStorage.setItem(STORAGE_KEY + ':settings', JSON.stringify({
            mode: mode,
            cone: coneEl.value,
            lastShrinkage: sEl.value,
            lastW: wEl.value,
            lastH: hEl.value,
            lastClay: selectedClayId,
          }));
        } catch (e) { /* ignore */ }
      }

      function saveHistory() {
        try {
          localStorage.setItem(STORAGE_KEY + ':history', JSON.stringify(history));
        } catch (e) { /* ignore */ }
      }

      function load() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY + ':settings');
          if (raw) {
            const d = JSON.parse(raw);
            if (d.mode === 'forward' || d.mode === 'reverse') mode = d.mode;
            if (d.cone) {
              // Only restore the saved cone if it still exists in the list.
              const coneOpt = coneEl.querySelector('option[value="' + String(d.cone).replace(/"/g, '\\"') + '"]');
              if (coneOpt) coneEl.value = d.cone;
            }

            if (d.lastW) wEl.value = d.lastW;
            if (d.lastH) hEl.value = d.lastH;
            // Restore either the clay body (preferred) or the manual %.
            if (d.lastClay && setClayById(d.lastClay)) {
              sEl.value = '';
            } else if (d.lastShrinkage) {
              sEl.value = d.lastShrinkage;
            }
          }
        } catch (e) { /* no settings yet */ }

        try {
          const raw = localStorage.getItem(STORAGE_KEY + ':history');
          if (raw) {
            const parsed = JSON.parse(raw);
            if (Array.isArray(parsed)) history = parsed;
          }
        } catch (e) { /* no history yet */ }

        updateModeUI();
        calc();
        renderHistory();
      }

      clearBtn.addEventListener('click', () => {
        history = [];
        lastHistoryKey = null;
        try { localStorage.removeItem(STORAGE_KEY + ':history'); } catch (e) { /* ignore */ }
        renderHistory();
      });

      load();
    })();
  </script>

